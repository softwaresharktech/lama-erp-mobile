<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="Primary">#1C3F6E</Color>
    <Color x:Key="PrimaryHover">#2152A0</Color>
    <Color x:Key="PrimaryPress">#1A3A62</Color>
    <Color x:Key="PrimaryDark">#112745</Color>
    <Color x:Key="Accent">#F59E0B</Color>
    <Color x:Key="AccentPress">#D97706</Color>

    <!-- Backgrounds / surfaces -->
    <Color x:Key="Background">#F4F6FA</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceSubtle">#F3F4F6</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#4B5563</Color>
    <Color x:Key="TextTertiary">#9CA3AF</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- Borders / status -->
    <Color x:Key="Border">#E5E7EB</Color>
    <Color x:Key="BorderFocus">#4F8FE8</Color>
    <Color x:Key="Danger">#E11D48</Color>
    <Color x:Key="White">#FFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}" />

</ResourceDictionary>
